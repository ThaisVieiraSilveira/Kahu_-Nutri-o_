rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Safety Net: Catch-All Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Rules for White-label branding (tenants database)
    match /tenants/{tenantId} {
      // Publicly readable so the guardian portal renders with the customized theme or logo
      allow read: if true;
      // Writing (create/update/delete) is restricted strictly to authenticated admin users
      allow write: if request.auth != null;
    }
  }
}
