rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Safety Net: Catch-All Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Rules for White-label branding (tenants database)
    match /tenants/{tenantId} {
      // Publicly readable so the guardian portal renders with the customized theme or logo
      allow read: if true;
      // Writing (create/update/delete) is restricted strictly to authenticated user of that tenantId
      allow write: if request.auth != null && request.auth.uid == tenantId;
    }

    // Rules for Pets database
    match /pets/{petId} {
      // Restrict write to the authenticated tenant owner of the pet
      allow write: if request.auth != null && (
        (resource == null && request.resource.data.tenant_id == request.auth.uid) ||
        (resource != null && resource.data.tenant_id == request.auth.uid)
      );
      // Allow single document get publicly so that the public tutor profile works reliably,
      // but restrict listing/queries to the authenticated tenant owner.
      allow get: if true;
      allow list: if request.auth != null && (
        (resource == null && request.resource.data.tenant_id == request.auth.uid) ||
        (resource != null && resource.data.tenant_id == request.auth.uid)
      );
    }

    // Rules for public tutor access links
    match /tutorAccessLinks/{token} {
      allow get: if true;

      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.crecheId;

      allow update, delete: if request.auth != null
        && request.auth.uid == resource.data.crecheId;
    }

    // Rules for subcollections of pet details
    match /pets/{petId}/timeline/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /pets/{petId}/moments/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /pets/{petId}/boletins/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Rules for food and feeding logs/registros database
    match /registros/{regId} {
      // Restrict read/write to the authenticated tenant owner of the log
      allow read, write: if request.auth != null && (
        (resource == null && request.resource.data.tenant_id == request.auth.uid) ||
        (resource != null && resource.data.tenant_id == request.auth.uid)
      );
    }

    // Rules for pending registrations submitted by public users
    match /cadastros_pendentes/{cadastroId} {
      // Allow public creation (submitting form)
      allow create: if true;
      // Allow only the target tenant to read, update or delete
      allow read, update, delete: if request.auth != null && (
        (resource == null && request.resource.data.tenant_id == request.auth.uid) ||
        (resource != null && resource.data.tenant_id == request.auth.uid)
      );
    }
  }
}
